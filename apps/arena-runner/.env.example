# Required for OpenRouterAdapter.
OPENROUTER_API_KEY=sk-or-v1-...

# Required when passing --persist. Set ARENA_ADMIN_SECRET to the same
# value you ran `npx convex env set ARENA_ADMIN_SECRET <...>` with on
# the target deployment, and CONVEX_URL to that deployment's URL.
# CONVEX_URL=https://<your-deployment>.convex.cloud
# ARENA_ADMIN_SECRET=<hex string>

# Optional. Defaults to the public Modal deployment.
# ENGINE_BASE_URL=https://ctrlx--kingme-engine-api.modal.run

# Optional. OpenRouter uses these for attribution.
# OPENROUTER_HTTP_REFERER=https://kingme.dev
# OPENROUTER_APP_TITLE=kingme-arena-runner
